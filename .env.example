# PIAX's own database (a small Render Postgres instance, separate from the 3 products)
DATABASE_URL="postgresql://user:password@host:5432/piax"

# Gates every /people and /grants route in PIAX itself. Generate with:
#   openssl rand -hex 32
PIAX_ADMIN_TOKEN="replace-me"
PIAX_ADMIN_EMAIL="you@principiumtechnology.com"

# Where the PIAX frontend is hosted (for CORS)
PIAX_FRONTEND_URL="https://piax.principiumtechnology.com"

# --- QuickEstimate connector ---
# Internal/private URL for the QuickEstimate backend (not the public quickestimate.ai domain
# if you'd rather keep the /internal/piax/* routes off the public-facing host).
QUICKESTIMATE_INTERNAL_URL="https://api.quickestimate.ai"
# Must match PIAX_SHARED_SECRET set in quick-estimate-backend's env — generate with openssl rand -hex 32
QUICKESTIMATE_PIAX_SECRET="replace-me"

# --- Home360 connector ---
HOME360_INTERNAL_URL="https://api.myhomethreesixty.com"
HOME360_PIAX_SECRET="replace-me"

# --- Pora Cloud connector ---
PORA_INTERNAL_URL="https://api.poradata.com"
PORA_PIAX_SECRET="replace-me"
